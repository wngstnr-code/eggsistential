PORT=8000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

SESSION_SECRET=replace_with_a_long_random_secret_at_least_32_chars

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_supabase_service_role_key

# Solana cluster
NETWORK_NAME=solana-devnet
RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet
NATIVE_TOKEN_SYMBOL=SOL
MIN_RECOMMENDED_NATIVE_BALANCE=0.05

# Eggsistential program — all four point to the same Anchor program
GAME_VAULT_ADDRESS=
GAME_SETTLEMENT_ADDRESS=
TRUST_PASSPORT_ADDRESS=
FAUCET_CONTRACT_ADDRESS=

# Solana-specific addresses (PDAs + SPL token from initialize-config)
PROGRAM_ID=
CONFIG_PDA=
VAULT_AUTHORITY_PDA=
TOKEN_MINT=
VAULT_TOKEN_ACCOUNT=
TOKEN_DECIMALS=6
ADMIN_PUBKEY=
BACKEND_SIGNER_PUBKEY=

FAUCET_MODE=drip_to
FAUCET_AMOUNT_UNITS=1000000000
FAUCET_COOLDOWN_SECONDS=300

# Backend signer keypair (base58 secret key — same wallet that admin set as backend_signer)
BACKEND_PRIVATE_KEY=

SETTLEMENT_SIGNATURE_TTL_SECONDS=86400
PASSPORT_SIGNATURE_TTL_SECONDS=900
PASSPORT_VALIDITY_SECONDS=2592000
MINIPAY_UNVERIFIED_AUTH_ENABLED=true
